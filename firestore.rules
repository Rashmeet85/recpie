rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner() {
      return isSignedIn() && request.auth.token.email == 'h.r17731785@gmail.com';
    }

    function currentRole() {
      return isOwner()
        ? 'owner'
        : get(/databases/$(database)/documents/roles/$(request.auth.token.email)).data.role;
    }

    function canManageRecipes() {
      return isOwner() || currentRole() == 'admin';
    }

    match /recipes/{recipeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && canManageRecipes();
    }

    match /roles/{userEmail} {
      allow read: if isSignedIn() && (isOwner() || request.auth.token.email == userEmail);
      allow write: if isOwner();
    }
  }
}
